{
  "layer": "top",
  "position": "top",
  "height": 42,
  "margin-top": 4,
  "margin-right": 8,
  "margin-bottom": 0,
  "margin-left": 8,
  "modules-left": [
    "custom/launcher",
    "niri/workspaces",
    "niri/window"
  ],
  "modules-center": [
    "custom/mpris-prev",
    "mpris",
    "custom/mpris-next"
  ],
  "modules-right": [
    "custom/easyeffects",
    "tray",
    "clock",
    "wireplumber",
    "custom/updates",
    "network",
    "custom/notification",
    "custom/power"
  ],
  "niri/window": {
    "max-length": 50,
    "ellipsis": true,
    "format": "{}"
  },
  "custom/easyeffects": {
    "format": "{}",
    "on-click": "toggle-filter",
    "exec": "pgrep -x easyeffects >/dev/null 2>&1 && echo '¾░ó┤' || echo '¾░ó│'",
    "interval": 1
  },
  "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "´æª",
    "format-icons": [
      "´Çª",
      "´Çº",
      "´Ç¿"
    ],
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 1%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%-",
    "ignored-sinks": [
      "Easy Effects*",
      "Auto Gain (EasyEffects)"
    ],
    "ignored-sources": [
      "Easy Effects*"
    ],
    "tooltip": false
  },
  "network": {
    "format-wifi": "´ç½",
    "format-ethernet": "´â¿",
    "format-disconnected": "´äº",
    "tooltip": true,
    "tooltip-format": "{ifname} {ipaddr}\nÔåô {bandwidthDownBits}bps\nÔåæ {bandwidthUpBits}bps",
    "interval": 3
  },
  "tray": {
    "spacing": 8,
    "icon-size": 16,
    "show-passive-items": true,
    "icon-theme": "Papirus"
  },
  "clock": {
    "interval": 1,
    "format": "{:%H:%M:%S  -  %d/%m/%Y}",
    "tooltip-format": "{:%A, %d %B %Y %H:%M:%S}",
    "on-click": "gsimplecal &"
  },
  "custom/launcher": {
    "format": "¾░êå",
    "on-click": "rofi -show drun",
    "tooltip": false
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "none": "´éó ",
      "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-none": "´çÀ",
      "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-inhibited-none": "´çÀ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "mpris": {
    "format": "{player_icon} {artist} {status_icon} {title}",
    "max-length": 50,
    "ellipsis": true,
    "player-icons": {
      "spotify": "´å╝",
      "firefox": "´ë®",
    },
    "status-icons": {
      "paused": "´üî",
      "playing": "´üï",
      "stopped": "´üì",
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctld shift",
    "on-scroll-down": "playerctld unshift",
    "ignored-players": [
      "chromium"
    ],
    "title-len": 20,
    "artist-len": 10,
  },
  "custom/mpris-prev": {
    "format": "ÔƒÁ",
    "on-click": "playerctld unshift",
    "tooltip": false
  },
  "custom/mpris-next": {
    "format": "ÔƒÂ",
    "on-click": "playerctld shift",
    "tooltip": false
  },
  "custom/updates": {
    "format": "{}",
    "exec": "(checkupdates 2>/dev/null && yay -Qua 2>/dev/null) | wc -l | awk '{print ($1>0)?\"´ÇÖ \"$1:\"´ÇÖ\"}'",
    "interval": 21600,
    "on-click": "wezterm -e yay -Syu --noconfirm --answerupgrade Y & notify-send 'Ô£à system updated'",
    "tooltip": false
  },
  "custom/power": {
    "format": "ÔÅ╗",
    "on-click": "rofi -show powermenu -modi \"powermenu:rofi-power-menu\"",
    "tooltip": false
  }
}
