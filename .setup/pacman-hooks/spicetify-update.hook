[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = spotify

[Action]
Description = Patching Spotify with Spicetify...
When = PostTransaction
Exec = /usr/bin/bash -c "chmod a+wr /opt/spotify && chmod a+wr /opt/spotify/Apps -R && sudo -u cesar HOME=/home/cesar PATH=$PATH:/home/cesar/.spicetify /home/cesar/.spicetify/spicetify backup apply"
